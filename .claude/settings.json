{
  "permissions": {
    "allow": ["Bash(git:*)", "Bash(bundle:*)"],
    "deny": ["Bash(rm -rf:*)", "Bash(sudo:*)", "Read(.env)"]
  },
  "includeCoAuthoredBy": false,
  "env": {
    "CLAUDE_CODE_NEW_INIT": "true"
  },
  "language": "ja",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; case \"$f\" in *.rb) bundle exec rubocop -A \"$f\" 2>/dev/null ;; esac; } || true",
            "timeout": 30,
            "statusMessage": "RuboCop auto-correct..."
          }
        ]
      }
    ]
  }
}
